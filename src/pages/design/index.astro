---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const examples = [
	"A modern card component with title, description, icon, and hover effect for a blog post",
	"A dashboard stats panel with 4 metric cards — Users, Revenue, Sessions, Bounce Rate — each with a colored icon and trend arrow",
	"A responsive navigation bar with logo, 5 links, and a mobile hamburger menu in dark theme",
	"A settings panel with toggle switches, dropdown selects, and a prominent save button",
	"A pricing table with 3 tiers: Free ($0), Pro ($29/mo), Enterprise ($99/mo) with feature lists and CTA buttons",
	"A contact form with name, email, message fields, styled submit button, and success state",
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`UI/UX Design Generator — ${SITE_TITLE}`}
			description="Describe a UI component and get instant HTML/CSS. Choose from examples or write your own prompt."
		/>
		<style>
			/* ── Layout ── */
			.design-page {
				display: grid;
				grid-template-columns: 420px 1fr;
				gap: 1.5em;
				align-items: start;
				min-height: calc(100vh - var(--nav-height) - 8em);
			}
			.prompt-panel {
				position: sticky;
				top: calc(var(--nav-height) + 1.5em);
			}

			/* ── Examples ── */
			.examples-label {
				font-size: 0.78em;
				font-weight: 600;
				color: var(--text-secondary);
				text-transform: uppercase;
				letter-spacing: 0.05em;
				margin-bottom: 0.75em;
			}
			.example-btns {
				display: flex;
				flex-direction: column;
				gap: 0.4em;
				margin-bottom: 1.25em;
			}
			.example-btn {
				text-align: left;
				padding: 0.6em 0.9em;
				font-size: 0.82em;
				font-family: inherit;
				color: var(--text-secondary);
				background: var(--bg-secondary);
				border: 1px solid var(--border);
				border-radius: var(--radius-md);
				cursor: pointer;
				transition: all 0.15s ease;
				line-height: 1.4;
			}
			.example-btn:hover {
				border-color: var(--accent);
				color: #fff;
				background: var(--bg-tertiary);
			}
			.example-btn:active { transform: scale(0.98); }

			/* ── Prompt Input ── */
			.prompt-area {
				width: 100%;
				min-height: 100px;
				padding: 0.75em 1em;
				font-family: inherit;
				font-size: 0.9em;
				color: var(--text-primary);
				background: var(--bg-secondary);
				border: 1px solid var(--border);
				border-radius: var(--radius-md);
				resize: vertical;
				outline: none;
				transition: border-color 0.15s;
				box-sizing: border-box;
				line-height: 1.6;
			}
			.prompt-area:focus {
				border-color: var(--accent);
				box-shadow: 0 0 0 2px var(--accent-glow);
			}
			.prompt-area::placeholder { color: var(--text-muted); }

			/* ── Generate Button ── */
			.generate-btn {
				width: 100%;
				margin-top: 0.75em;
				padding: 0.7em 1.5em;
				font-size: 0.95em;
				font-weight: 600;
				font-family: inherit;
				color: var(--bg);
				background: var(--accent);
				border: none;
				border-radius: var(--radius-md);
				cursor: pointer;
				transition: all 0.15s ease;
			}
			.generate-btn:hover { background: var(--accent-light); }
			.generate-btn:active { transform: scale(0.98); }
			.generate-btn:disabled {
				opacity: 0.5;
				cursor: not-allowed;
				transform: none;
			}
			.generate-btn .spinner {
				display: none;
				width: 16px; height: 16px;
				border: 2px solid var(--accent-dark);
				border-top-color: transparent;
				border-radius: 50%;
				animation: spin 0.7s linear infinite;
				margin: 0 auto;
			}
			.generate-btn.loading .spinner { display: block; }
			.generate-btn.loading .label { display: none; }
			@keyframes spin { to { transform: rotate(360deg); } }

			/* ── Results Panel ── */
			.results-panel {
				border: 1px solid var(--border);
				border-radius: var(--radius-lg);
				overflow: hidden;
				background: var(--bg-secondary);
				min-height: 300px;
				display: flex;
				flex-direction: column;
			}
			.results-panel.empty {
				display: flex;
				align-items: center;
				justify-content: center;
				color: var(--text-muted);
				font-size: 0.9em;
				min-height: 300px;
			}
			.results-panel.empty .empty-icon {
				font-size: 2.5em;
				margin-bottom: 0.5em;
			}
			.results-panel.empty .empty-text {
				text-align: center;
				line-height: 1.6;
				max-width: 260px;
			}

			/* ── Tab Bar ── */
			.tab-bar {
				display: flex;
				border-bottom: 1px solid var(--border);
				background: var(--bg);
				flex-shrink: 0;
			}
			.tab-btn {
				padding: 0.6em 1.2em;
				font-size: 0.82em;
				font-family: inherit;
				color: var(--text-muted);
				background: transparent;
				border: none;
				border-bottom: 2px solid transparent;
				cursor: pointer;
				transition: all 0.15s;
				font-weight: 500;
			}
			.tab-btn:hover { color: var(--text-secondary); }
			.tab-btn.active {
				color: var(--accent-light);
				border-bottom-color: var(--accent);
			}

			/* ── Preview Tab ── */
			.preview-frame {
				flex: 1;
				width: 100%;
				border: none;
				background: #fff;
				min-height: 400px;
			}
			.tab-content { display: none; flex: 1; }
			.tab-content.active { display: flex; flex-direction: column; }

			/* ── Code Tab ── */
			.code-block {
				flex: 1;
				margin: 0;
				padding: 1em 1.25em;
				font-family: var(--font-mono);
				font-size: 0.78em;
				line-height: 1.6;
				color: var(--text-primary);
				overflow: auto;
				white-space: pre-wrap;
				word-break: break-all;
				max-height: 500px;
			}
			.copy-btn {
				position: absolute;
				top: 0.5em;
				right: 0.5em;
				padding: 0.3em 0.7em;
				font-size: 0.72em;
				font-family: inherit;
				color: var(--text-muted);
				background: var(--bg-tertiary);
				border: 1px solid var(--border);
				border-radius: var(--radius-sm);
				cursor: pointer;
				transition: all 0.15s;
			}
			.copy-btn:hover { color: #fff; border-color: var(--accent); }
			.code-tab-wrap { position: relative; flex: 1; display: flex; }

			/* ── Error ── */
			.error-msg {
				color: #ff6b6b;
				font-size: 0.85em;
				margin-top: 0.5em;
				display: none;
			}
			.error-msg.visible { display: block; }

			@media (max-width: 860px) {
				.design-page { grid-template-columns: 1fr; }
				.prompt-panel { position: static; }
				.preview-frame { min-height: 300px; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header" style="padding:1em 0 0.5em;text-align:left;">
				<h1 style="font-size:2rem;">UI/UX Design Generator</h1>
				<p class="subtitle" style="font-size:0.95em;">
					Describe a UI component — get instant HTML + CSS. Pick an example or write your own.
				</p>
			</div>

			<div class="design-page">
				<!-- Prompt Panel -->
				<div class="prompt-panel">
					<div class="examples-label">Examples</div>
					<div class="example-btns" id="example-btns">
						{examples.map((ex) => (
							<button class="example-btn" data-example={ex}>{ex}</button>
						))}
					</div>
					<textarea class="prompt-area" id="prompt-input" placeholder="Describe the UI component you want to generate..."></textarea>
					<button class="generate-btn" id="generate-btn">
						<span class="label">Generate Design</span>
						<span class="spinner"></span>
					</button>
					<div class="error-msg" id="error-msg"></div>
				</div>

				<!-- Results Panel -->
				<div class="results-panel empty" id="results-panel">
					<div style="text-align:center;padding:2em;">
						<div class="empty-icon">🎨</div>
						<div class="empty-text">
							Enter a prompt or pick an example above,<br />
							then click <strong>Generate Design</strong>.
						</div>
					</div>
				</div>
			</div>
		</main>
		<Footer />

		<script>
			const promptInput = document.getElementById('prompt-input');
			const generateBtn = document.getElementById('generate-btn');
			const resultsPanel = document.getElementById('results-panel');
			const errorMsg = document.getElementById('error-msg');

			let currentHtml = '';
			let currentCss = '';

			// ── Examples ──
			document.getElementById('example-btns').addEventListener('click', (e) => {
				const btn = e.target.closest('.example-btn');
				if (btn) {
					promptInput.value = btn.dataset.example;
					promptInput.focus();
				}
			});

			// ── Generate ──
			generateBtn.addEventListener('click', generate);
			promptInput.addEventListener('keydown', (e) => {
				if (e.key === 'Enter' && e.metaKey) generate();
				if (e.key === 'Enter' && e.ctrlKey) generate();
			});

			async function generate() {
				const prompt = promptInput.value.trim();
				if (!prompt) {
					showError('Please enter a prompt first.');
					return;
				}

				generateBtn.classList.add('loading');
				generateBtn.disabled = true;
				errorMsg.classList.remove('visible');
				showLoading();

				try {
					const res = await fetch('/api/design', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ prompt }),
					});

					const data = await res.json();

					if (!res.ok) {
						showError(data.error || `Server error (${res.status})`);
						return;
					}

					if (!data.html && !data.css) {
						showError('The generator returned empty output. Try a different prompt.');
						return;
					}

					currentHtml = data.html || '';
					currentCss = data.css || '';
					showResults(currentHtml, currentCss);

				} catch (err) {
					showError('Network error — check your connection and try again.');
				} finally {
					generateBtn.classList.remove('loading');
					generateBtn.disabled = false;
				}
			}

			function showLoading() {
				resultsPanel.className = 'results-panel empty';
				resultsPanel.innerHTML = `
					<div style="text-align:center;padding:3em;">
						<div style="width:24px;height:24px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.7s linear infinite;margin:0 auto 1em;"></div>
						<div class="empty-text">Generating...<br/>this takes ~10 seconds</div>
					</div>
				`;
			}

			function showResults(html, css) {
				const fullHtml = css
					? `<!DOCTYPE html><html><head><style>${css}</style></head><body>${html}</body></html>`
					: html;

				resultsPanel.className = 'results-panel';
				resultsPanel.innerHTML = `
					<div class="tab-bar">
						<button class="tab-btn active" data-tab="preview">Preview</button>
						<button class="tab-btn" data-tab="code">Code</button>
					</div>
					<div class="tab-content active" id="tab-preview">
						<iframe class="preview-frame" srcdoc="${escapeHtml(fullHtml)}" title="Design Preview"></iframe>
					</div>
					<div class="tab-content" id="tab-code">
						<div class="code-tab-wrap">
							<button class="copy-btn" id="copy-btn">Copy Code</button>
							<pre class="code-block">${escapeHtml(css ? css + '\n\n/* ── HTML ── */\n' + html : html)}</pre>
						</div>
					</div>
				`;

				// Tab switching
				resultsPanel.querySelectorAll('.tab-btn').forEach(btn => {
					btn.addEventListener('click', () => {
						resultsPanel.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
						resultsPanel.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
						btn.classList.add('active');
						const tab = document.getElementById(`tab-${btn.dataset.tab}`);
						if (tab) tab.classList.add('active');
					});
				});

				// Copy button
				const copyBtn = document.getElementById('copy-btn');
				if (copyBtn) {
					copyBtn.addEventListener('click', async () => {
						const code = currentCss
							? `/* CSS */\n${currentCss}\n\n<!-- HTML -->\n${currentHtml}`
							: currentHtml;
						await navigator.clipboard.writeText(code);
						copyBtn.textContent = 'Copied!';
						setTimeout(() => { copyBtn.textContent = 'Copy Code'; }, 2000);
					});
				}
			}

			function showError(msg) {
				errorMsg.textContent = msg;
				errorMsg.classList.add('visible');
				resultsPanel.className = 'results-panel empty';
				resultsPanel.innerHTML = `
					<div style="text-align:center;padding:2em;color:var(--text-muted);">
						<div style="font-size:2em;margin-bottom:0.5em;">⚠️</div>
						<div class="empty-text">${escapeHtml(msg)}</div>
					</div>
				`;
			}

			function escapeHtml(str) {
				return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
			}
		</script>
	</body>
</html>
