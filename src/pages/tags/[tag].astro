---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const allTags = new Set<string>();
	for (const post of posts) {
		for (const tag of post.data.tags) {
			allTags.add(tag);
		}
	}
	return Array.from(allTags).map((tag) => ({
		params: { tag },
		props: { tag },
	}));
}

const { tag } = Astro.params;
const allPosts = await getCollection('blog');
const taggedPosts = allPosts
	.filter((post) => post.data.tags.includes(tag!))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${tag} tutorials — ${SITE_TITLE}`}
			description={`Tutorials tagged with "${tag}" — Hermes Agent guides and tutorials.`}
		/>
		<style>
			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.3em;
				margin-bottom: 1.5em;
				color: var(--text-muted);
				font-size: 0.88em;
				text-decoration: none;
				transition: color 0.15s;
			}
			.back-link:hover { color: var(--accent-light); }
			h1 { margin-bottom: 0.1em; text-transform: capitalize; font-size: 2.5rem; }
			.post-count { color: var(--text-muted); font-size: 0.9em; margin-bottom: 2em; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<a class="back-link" href="/blog">&larr; Back to all tutorials</a>
			<h1>#{tag}</h1>
			<p class="post-count">{taggedPosts.length} tutorial{taggedPosts.length !== 1 ? 's' : ''}</p>
			<div class="card-grid">
				{taggedPosts.map((post) => (
					<a class="card" href={`/blog/${post.id}/`} style="text-decoration:none;color:inherit;cursor:pointer;">
						<div class="top-row" style="margin-bottom:0.5em;">
							<h2>{post.data.title}</h2>
						</div>
						<div class="category-label">
							<FormattedDate date={post.data.pubDate} />
						</div>
						<p>{post.data.description}</p>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>