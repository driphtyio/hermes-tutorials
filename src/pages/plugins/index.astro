---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { plugins, categories } from '../../data/plugins';

const totalPlugins = plugins.length;
const bundledCount = plugins.filter(p => p.status === 'bundled').length;
const communityCount = plugins.filter(p => p.status === 'community' || p.status === 'request').length;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Plugin Marketplace — ${SITE_TITLE}`} description="Browse, search, and install Hermes Agent plugins. 55+ plugins across 9 categories with ratings, requirements, and install instructions." />
		<style>
			.badge-bundled { background: rgba(46, 125, 50, 0.2); color: #66bb6a; }
			.badge-community { background: rgba(230, 81, 0, 0.2); color: #ffa726; }
			.badge-request { background: rgba(198, 40, 40, 0.2); color: #ef5350; }
			.card .details { font-size: 0.78em; color: var(--text-muted); margin-bottom: 0.8em; line-height: 1.6; }
			.card .details strong { color: var(--text-secondary); }
			.card .actions { display: flex; gap: 0.4em; }
			.card .issue-link { font-size: 0.78em; }
			.card .issue-link a { color: var(--accent-light); }
			.install-cmd {
				background: var(--bg); color: var(--text-primary); padding: 0.35em 0.7em;
				border-radius: var(--radius-sm); font-size: 0.78em; font-family: var(--font-mono);
				user-select: all; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
				border: 1px solid var(--border);
			}
			.copy-btn {
				background: var(--accent); color: #fff; border: none; border-radius: var(--radius-sm);
				padding: 0.35em 0.7em; font-size: 0.78em; cursor: pointer; white-space: nowrap;
				transition: background 0.15s; font-family: inherit;
			}
			.copy-btn:hover { background: var(--accent-dark); }
			.copy-btn.copied { background: #2e7d32; }
			@media (max-width: 720px) {
				.install-cmd { white-space: normal; overflow: visible; word-break: break-all; font-size: 0.72em; padding: 0.35em 0.6em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Plugin Marketplace</h1>
				<p class="subtitle">Browse, search, and install plugins for Hermes Agent. {bundledCount} bundled + {communityCount} community/requested.</p>
			</div>

			<div class="stats-bar">
				<div class="stat-item"><div class="stat-number">{totalPlugins}</div><div class="stat-label">Total Plugins</div></div>
				<div class="stat-item"><div class="stat-number">{bundledCount}</div><div class="stat-label">Bundled</div></div>
				<div class="stat-item"><div class="stat-number">{categories.length}</div><div class="stat-label">Categories</div></div>
				<div class="stat-item"><div class="stat-number">{plugins.filter(p => p.rating >= 4).length}</div><div class="stat-label">Top Rated ★4+</div></div>
			</div>

			<div class="search-box">
				<input class="search-input" type="text" id="search" placeholder="Search plugins..." />
			</div>

			<div class="filter-bar" id="filters">
				<button class="filter-btn active" data-cat="all">All</button>
				{categories.map(cat => (
					<button class="filter-btn" data-cat={cat.id}>
						{cat.icon} {cat.label}
					</button>
				))}
			</div>

			<div class="card-grid" id="pluginGrid">
				{plugins.map((p, i) => (
					<div class="card" data-category={p.category} data-rating={p.rating} data-status={p.status} data-name={p.name.toLowerCase()} data-desc={p.description.toLowerCase()}>
						<div class="category-label">{categories.find(c => c.id === p.category)?.icon} {categories.find(c => c.id === p.category)?.label}</div>
						<div class="top-row">
							<div class="name-row">
								<h2>{p.name}</h2>
								{p.status === 'bundled' && <span class="badge badge-bundled">Bundled</span>}
								{p.status === 'community' && <span class="badge badge-community">Community</span>}
								{p.status === 'request' && <span class="badge badge-request">Request</span>}
							</div>
							{p.rating > 0 && <div class="rating">{'★'.repeat(p.rating)}{'☆'.repeat(5 - p.rating)}</div>}
						</div>
						<p>{p.description}</p>
						<div class="details">
							{p.autoLoad ? '✅ Auto-loaded' : '🔌 Opt-in'}
							<span> · </span><strong>Type:</strong> {p.kind}
							<br /><strong>Requires:</strong> {p.requirements}
							{p.auth !== 'None' && <><br /><strong>Auth:</strong> {p.auth}</>}
							{p.githubIssue && <><br /><span class="issue-link">🐛 <a href={`https://github.com/NousResearch/hermes-agent/issues/${p.githubIssue.replace('#', '')}`} target="_blank">{p.githubIssue}</a></span></>}
						</div>
						{p.installHint !== 'None' && p.status !== 'request' && (
							<div class="actions">
								<span class="install-cmd" id={`cmd-${i}`}>{p.installHint}</span>
								<button class="copy-btn" data-cmd-index={i}>Copy</button>
							</div>
						)}
					</div>
				))}
			</div>

			<div class="empty-state" id="emptyState">
				<div class="emoji">🔍</div>
				<p>No plugins match your search. Try a different filter or keyword.</p>
			</div>
		</main>
		<Footer />

		<script>
			const search = document.getElementById('search');
			const filterBtns = document.querySelectorAll('.filter-btn');
			const cards = document.querySelectorAll('.card');
			const emptyState = document.getElementById('emptyState');

			let activeCategory = 'all';

			function filterPlugins() {
				const query = search.value.toLowerCase();
				let visible = 0;
				cards.forEach(card => {
					const cat = card.dataset.category;
					const name = card.dataset.name;
					const desc = card.dataset.desc;
					const matchesCat = activeCategory === 'all' || cat === activeCategory;
					const matchesSearch = !query || name.includes(query) || desc.includes(query);
					card.style.display = matchesCat && matchesSearch ? '' : 'none';
					if (matchesCat && matchesSearch) visible++;
				});
				emptyState.style.display = visible === 0 ? '' : 'none';
			}

			function setCategory(cat) {
				activeCategory = cat;
				filterBtns.forEach(b => {
					b.classList.toggle('active', b.dataset.cat === cat);
				});
				filterPlugins();
			}

			filterBtns.forEach(btn => {
				btn.addEventListener('click', () => setCategory(btn.dataset.cat));
			});

			search.addEventListener('input', filterPlugins);

			document.querySelectorAll('.copy-btn').forEach(btn => {
				btn.addEventListener('click', () => {
					const el = document.getElementById('cmd-' + btn.dataset.cmdIndex);
					navigator.clipboard.writeText(el.textContent).then(() => {
						btn.textContent = 'Copied!';
						btn.classList.add('copied');
						setTimeout(() => {
							btn.textContent = 'Copy';
							btn.classList.remove('copied');
						}, 2000);
					});
				});
			});
		</script>
	</body>
</html>
