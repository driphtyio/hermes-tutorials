---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { tools, toolCategories } from '../../data/tools';

const total = tools.length;
const defaultOn = tools.filter(t => t.defaultEnabled).length;
const optional = total - defaultOn;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Tools — ${SITE_TITLE}`} description={`Browse ${total} Hermes Agent tools across ${toolCategories.length} categories with ratings, requirements, capabilities, and pitfalls.`} />
		<style>
			.badge-on { background: rgba(46, 125, 50, 0.2); color: #66bb6a; }
			.badge-off { background: rgba(230, 81, 0, 0.2); color: #ffa726; }
			.cap-tag {
				font-size: 0.7em; padding: 0.15em 0.5em; border-radius: 4px;
				background: rgba(108, 92, 231, 0.1); color: var(--accent-light);
				border: 1px solid rgba(108, 92, 231, 0.2);
			}
			.card .caps { display: flex; flex-wrap: wrap; gap: 0.3em; margin-bottom: 0.6em; }
			.card .details { font-size: 0.78em; color: var(--text-muted); margin-bottom: 0.6em; line-height: 1.6; }
			.card .details strong { color: var(--text-secondary); }
			.pitfall {
				font-size: 0.75em; color: var(--text-muted); padding: 0.5em 0.7em;
				border-left: 2px solid rgba(239, 83, 80, 0.4); margin-top: 0.3em;
				background: rgba(239, 83, 80, 0.04); border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
			}
			.pitfall::before { content: '⚠️ '; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Tools Reference</h1>
				<p class="subtitle">Every Hermes Agent tool across {toolCategories.length} categories — {defaultOn} enabled by default, {optional} opt-in.</p>
			</div>

			<div class="stats-bar">
				<div class="stat-item"><div class="stat-number">{total}</div><div class="stat-label">Total Tools</div></div>
				<div class="stat-item"><div class="stat-number">{toolCategories.length}</div><div class="stat-label">Categories</div></div>
				<div class="stat-item"><div class="stat-number">{defaultOn}</div><div class="stat-label">Default On</div></div>
				<div class="stat-item"><div class="stat-number">{tools.filter(t => t.rating >= 4).length}</div><div class="stat-label">Top Rated ★4+</div></div>
			</div>

			<div class="search-box">
				<input class="search-input" type="text" id="search" placeholder="Search tools..." />
			</div>

			<div class="filter-bar" id="filters">
				<button class="filter-btn active" data-cat="all">All</button>
				{toolCategories.map(cat => (
					<button class="filter-btn" data-cat={cat.id}>
						{cat.icon} {cat.label}
					</button>
				))}
			</div>

			<div class="card-grid" id="toolGrid">
				{tools.map((t, i) => (
					<div class="card" data-category={t.category} data-name={t.name.toLowerCase()} data-desc={t.description.toLowerCase()}>
						<div class="category-label">{toolCategories.find(c => c.id === t.category)?.icon} {toolCategories.find(c => c.id === t.category)?.label}</div>
						<div class="top-row">
							<div class="name-row">
								<h2>{t.name}</h2>
								{t.defaultEnabled
									? <span class="badge badge-on">Default On</span>
									: <span class="badge badge-off">Opt-in</span>
								}
							</div>
							{t.rating > 0 && <div class="rating">{'★'.repeat(t.rating)}{'☆'.repeat(5 - t.rating)}</div>}
						</div>
						<p>{t.description}</p>
						<div class="caps">
							{t.capabilities.map(cap => <span class="cap-tag">{cap}</span>)}
						</div>
						<div class="details">
							{t.requiresEnv.length > 0 && <><strong>Requires:</strong> {t.requiresEnv.join(', ')}<br /></>}
						</div>
						{t.pitfalls && <div class="pitfall">{t.pitfalls}</div>}
					</div>
				))}
			</div>

			<div class="empty-state" id="emptyState">
				<div class="emoji">🔍</div>
				<p>No tools match your search. Try a different filter or keyword.</p>
			</div>
		</main>
		<Footer />

		<script>
			const search = document.getElementById('search');
			const filterBtns = document.querySelectorAll('.filter-btn');
			const cards = document.querySelectorAll('.card');
			const emptyState = document.getElementById('emptyState');
			let activeCategory = 'all';

			function filterTools() {
				const query = search.value.toLowerCase();
				let visible = 0;
				cards.forEach(card => {
					const cat = card.dataset.category;
					const name = card.dataset.name;
					const desc = card.dataset.desc;
					const matchesCat = activeCategory === 'all' || cat === activeCategory;
					const matchesSearch = !query || name.includes(query) || desc.includes(query);
					card.style.display = matchesCat && matchesSearch ? '' : 'none';
					if (matchesCat && matchesSearch) visible++;
				});
				emptyState.style.display = visible === 0 ? '' : 'none';
			}

			function setCategory(cat) {
				activeCategory = cat;
				filterBtns.forEach(b => b.classList.toggle('active', b.dataset.cat === cat));
				filterTools();
			}

			filterBtns.forEach(btn => btn.addEventListener('click', () => setCategory(btn.dataset.cat)));
			search.addEventListener('input', filterTools);
		</script>
	</body>
</html>