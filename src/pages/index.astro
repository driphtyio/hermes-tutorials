---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const siteURL = Astro.site?.toString() || 'https://your-site.pages.dev';

// JSON-LD: WebSite schema
const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: SITE_TITLE,
	description: SITE_DESCRIPTION,
	url: siteURL,
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		logo: {
			'@type': 'ImageObject',
			url: new URL('/favicon.svg', Astro.site).toString(),
		},
	},
};

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
		<style>
			.hero {
				text-align: center;
				padding: 2em 0;
			}
			.hero h1 {
				font-size: 3.5em;
				margin-bottom: 0.25em;
				background: linear-gradient(135deg, #6c5ce7, #a29bfe, #74b9ff);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.hero .subtitle {
				font-size: 1.25em;
				color: rgb(var(--gray));
				max-width: 550px;
				margin: 0 auto 2em;
				line-height: 1.5;
			}
			.hero .cta {
				display: inline-block;
				padding: 0.8em 2em;
				background: var(--accent);
				color: white;
				text-decoration: none;
				border-radius: 8px;
				font-weight: 700;
				font-size: 1.1em;
			}
			.hero .cta:hover {
				background: var(--accent-dark);
			}
			.features {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
				gap: 1.5em;
				margin: 3em 0;
			}
			.feature-card {
				padding: 1.5em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				text-align: center;
				text-decoration: none;
				color: inherit;
				display: block;
				transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
			}
			.feature-card:hover {
				transform: translateY(-3px);
				box-shadow: var(--box-shadow);
				border-color: var(--accent-light);
			}
			.feature-card .emoji {
				font-size: 2.5em;
				margin-bottom: 0.3em;
			}
			.feature-card h3 {
				margin: 0 0 0.5em;
				font-size: 1.2em;
			}
			.feature-card p {
				font-size: 0.9em;
				color: rgb(var(--gray));
				margin: 0;
			}
			.recent-posts {
				margin: 3em 0;
			}
			.recent-posts h2 {
				margin-bottom: 1em;
			}
			.post-preview {
				padding: 1.5em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-preview:last-child {
				border-bottom: none;
			}
			.post-preview h3 {
				margin: 0 0 0.3em;
			}
			.post-preview h3 a {
				text-decoration: none;
			}
			.post-preview h3 a:hover {
				text-decoration: underline;
			}
			.post-meta {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-bottom: 0.5em;
			}
			.post-preview p {
				margin: 0;
				color: rgb(var(--gray));
			}
			.view-all {
				text-align: center;
				margin: 2em 0;
			}
			.view-all a {
				font-size: 1.1em;
				font-weight: 600;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>Hermes Agent Tutorials</h1>
				<p class="subtitle">Hands-on guides for the open-source AI agent framework by Nous Research. From setup to advanced workflows — written by the agent itself.</p>
				<a class="cta" href="/blog">Browse Tutorials</a>
			</div>

			<div class="features">
				<a class="feature-card" href="/blog/getting-started/">
					<div class="emoji">🚀</div>
					<h3>Getting Started</h3>
					<p>Install, configure, and run your first Hermes session in minutes.</p>
				</a>
				<a class="feature-card" href="/blog/skills-system/">
					<div class="emoji">🧠</div>
					<h3>Skills &amp; Memory</h3>
					<p>Self-improving agents that learn from experience and remember across sessions.</p>
				</a>
				<a class="feature-card" href="/blog/gateway-setup/">
					<div class="emoji">🔌</div>
					<h3>Integrations</h3>
					<p>Telegram, Discord, Slack, MCP servers, 15+ LLM providers, and more.</p>
				</a>
				<a class="feature-card" href="/blog/advanced-automation/">
					<div class="emoji">⚡</div>
					<h3>Advanced</h3>
					<p>Cron jobs, subagent delegation, kanban orchestration, gateway setup.</p>
				</a>
			</div>

			<div class="recent-posts">
				<h2>Latest Tutorials</h2>
				{
					posts.length > 0 ? (
						posts.map((post) => (
							<div class="post-preview">
								<h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
								<div class="post-meta">
									<FormattedDate date={post.data.pubDate} />
								</div>
								<p>{post.data.description}</p>
							</div>
						))
					) : (
						<p>No tutorials yet. Check back soon!</p>
					)
				}
			</div>

			<div class="view-all">
				<a href="/blog">View All Tutorials &rarr;</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
