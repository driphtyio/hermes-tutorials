---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const siteURL = Astro.site?.toString() || 'https://your-site.pages.dev';

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: SITE_TITLE,
	description: SITE_DESCRIPTION,
	url: siteURL,
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', Astro.site).toString() },
	},
};

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
		<style>
			/* ── Hero ── */
			.hero {
				text-align: center;
				padding: 5em 0 3em;
			}
			.hero h1 {
				font-size: 4rem;
				font-weight: 700;
				letter-spacing: -0.04em;
				line-height: 1.05;
				margin-bottom: 0.4em;
				background: linear-gradient(135deg, #fff 30%, var(--accent-light) 60%, #74b9ff 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.hero .subtitle {
				font-size: 1.15em;
				color: var(--text-secondary);
				max-width: 540px;
				margin: 0 auto 2em;
				line-height: 1.6;
			}
			.hero-actions {
				display: flex;
				gap: 0.75em;
				justify-content: center;
				flex-wrap: wrap;
			}
			.hero-actions .btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.65em 1.5em;
				border-radius: 999px;
				font-size: 0.95em;
				font-weight: 600;
				text-decoration: none;
				transition: all 0.15s ease;
				cursor: pointer;
			}
			.btn-primary {
				background: #fff;
				color: var(--bg);
			}
			.btn-primary:hover {
				background: var(--accent-light);
				color: var(--bg);
			}
			.btn-secondary {
				background: var(--bg-tertiary);
				color: var(--text-primary);
				border: 1px solid var(--border);
			}
			.btn-secondary:hover {
				border-color: var(--accent);
				color: #fff;
			}

			/* ── Features Grid ── */
			.features {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1px;
				margin: 3em 0;
				border: 1px solid var(--border);
				border-radius: var(--radius-lg);
				overflow: hidden;
				background: var(--border);
			}
			.feature-card {
				padding: 1.75em;
				background: var(--bg);
				text-decoration: none;
				color: inherit;
				transition: all 0.15s ease;
				display: flex;
				flex-direction: column;
				gap: 0.3em;
			}
			.feature-card:hover {
				background: var(--bg-secondary);
			}
			.feature-card .feat-icon {
				font-size: 1.5em;
				margin-bottom: 0.25em;
			}
			.feature-card h3 {
				margin: 0;
				font-size: 0.95em;
				font-weight: 600;
				color: #fff;
				letter-spacing: -0.01em;
			}
			.feature-card p {
				margin: 0;
				font-size: 0.82em;
				color: var(--text-muted);
				line-height: 1.5;
			}

			/* ── Recent Posts ── */
			.section-title {
				font-size: 1.1em;
				font-weight: 600;
				color: var(--text-secondary);
				margin-bottom: 1.25em;
				letter-spacing: 0;
			}
			.posts-list {
				display: flex;
				flex-direction: column;
			}
			.post-item {
				padding: 1.25em 0;
				border-bottom: 1px solid var(--border);
				text-decoration: none;
				color: inherit;
				display: block;
				transition: all 0.15s ease;
			}
			.post-item:first-child { padding-top: 0; }
			.post-item:last-child { border-bottom: none; }
			.post-item:hover .post-title {
				color: var(--accent-light);
			}
			.post-title {
				font-size: 1.1em;
				font-weight: 600;
				color: #fff;
				margin: 0 0 0.3em;
				transition: color 0.15s ease;
				letter-spacing: -0.01em;
			}
			.post-meta {
				font-size: 0.82em;
				color: var(--text-muted);
				margin-bottom: 0.4em;
			}
			.post-item p {
				margin: 0;
				font-size: 0.88em;
				color: var(--text-secondary);
				line-height: 1.5;
			}
			.view-all {
				text-align: center;
				margin: 2em 0;
			}
			.view-all a {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				font-size: 0.95em;
				font-weight: 600;
				color: var(--accent-light);
			}
			.view-all a:hover {
				color: #fff;
			}

			@media (max-width: 720px) {
				.hero { padding: 3em 0 2em; }
				.hero h1 { font-size: 2.5rem; }
				.features { grid-template-columns: repeat(2, 1fr); }
			}
			@media (max-width: 480px) {
				.features { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>Hermes Agent Tutorials</h1>
				<p class="subtitle">Hands-on guides for the open-source AI agent framework by Nous Research. From setup to advanced workflows — written by the agent itself.</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="/blog">Browse Tutorials &rarr;</a>
					<a class="btn btn-secondary" href="/plugins">Plugin Marketplace</a>
				</div>
			</div>

			<div class="features">
				<a class="feature-card" href="/blog/getting-started/">
					<div class="feat-icon">🚀</div>
					<h3>Getting Started</h3>
					<p>Install, configure, and run your first Hermes session.</p>
				</a>
				<a class="feature-card" href="/blog/commands-reference/">
					<div class="feat-icon">⌨️</div>
					<h3>Commands</h3>
					<p>Complete CLI reference — every command and flag.</p>
				</a>
				<a class="feature-card" href="/blog/provider-setup/">
					<div class="feat-icon">🔑</div>
					<h3>Providers</h3>
					<p>Set up OpenRouter, local models, credential pools.</p>
				</a>
				<a class="feature-card" href="/blog/gateway-setup/">
					<div class="feat-icon">💬</div>
					<h3>Gateway</h3>
					<p>Run Hermes on Telegram, Discord, and Slack.</p>
				</a>
				<a class="feature-card" href="/plugins/">
					<div class="feat-icon">🧩</div>
					<h3>Plugins</h3>
					<p>Browse 55+ plugins across 9 categories.</p>
				</a>
				<a class="feature-card" href="/blog/memory-profiles/">
					<div class="feat-icon">🧠</div>
					<h3>Memory</h3>
					<p>Persistence, profiles, and voice interaction.</p>
				</a>
				<a class="feature-card" href="/blog/multi-agent-setup/">
					<div class="feat-icon">🤖</div>
					<h3>Multi-Agent</h3>
					<p>Parallel agents, worktree mode, delegation.</p>
				</a>
				<a class="feature-card" href="/blog/advanced-automation/">
					<div class="feat-icon">⚡</div>
					<h3>Automation</h3>
					<p>Cron, MCP, and autonomous pipelines.</p>
				</a>
				<a class="feature-card" href="/blog/troubleshooting/">
					<div class="feat-icon">🛠️</div>
					<h3>Troubleshooting</h3>
					<p>Fix common issues with hermes doctor.</p>
				</a>
			</div>

			<div>
				<h2 class="section-title">Latest Tutorials</h2>
				<div class="posts-list">
					{posts.map((post) => (
						<a class="post-item" href={`/blog/${post.id}/`}>
							<h3 class="post-title">{post.data.title}</h3>
							<div class="post-meta">
								<FormattedDate date={post.data.pubDate} />
								{post.data.tags.length > 0 && <span> &middot; {post.data.tags.slice(0, 3).join(', ')}</span>}
							</div>
							<p>{post.data.description}</p>
						</a>
					))}
				</div>
			</div>

			<div class="view-all">
				<a href="/blog">View All Tutorials &rarr;</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
