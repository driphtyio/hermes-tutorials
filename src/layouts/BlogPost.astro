---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

interface Props {
	post: CollectionEntry<'blog'>;
	readingTime: number;
}

const { post, readingTime } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags, author, keywords } = post.data;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	author: { '@type': 'Person', name: author },
	publisher: {
		'@type': 'Organization', name: 'Hermes Agent Tutorials',
		logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', Astro.site).toString() },
	},
	datePublished: pubDate.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
	...(tags.length > 0 && { keywords: tags.join(', ') }),
	wordCount: readingTime * 200,
	timeRequired: `PT${readingTime}M`,
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
		{ '@type': 'ListItem', position: 2, name: 'Tutorials', item: new URL('/blog', Astro.site).toString() },
		{ '@type': 'ListItem', position: 3, name: title, item: canonicalURL.toString() },
	],
};
---

<html lang="en">
	<head>
		<BaseHead
			title={`${title} — Hermes Agent Tutorials`}
			description={description}
			image={heroImage}
			type="article"
			pubDate={pubDate}
			updatedDate={updatedDate}
			tags={tags}
			keywords={keywords}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		<style>
			/* ── Breadcrumbs ── */
			.breadcrumbs {
				max-width: var(--content-width);
				margin: 0 auto;
				padding: 1em 1em 0;
				font-size: 0.82em;
				color: var(--text-muted);
			}
			.breadcrumbs a { color: var(--text-muted); }
			.breadcrumbs a:hover { color: var(--accent-light); }
			.breadcrumbs .sep { margin: 0 0.4em; color: var(--border-light); }

			/* ── Post Header ── */
			.post-header {
				margin-bottom: 2.5em;
				padding: 0.5em 0;
			}
			.post-header h1 {
				font-size: 2.8rem;
				font-weight: 700;
				letter-spacing: -0.03em;
				line-height: 1.1;
				margin: 0 0 0.5em;
			}
			.post-meta {
				color: var(--text-muted);
				font-size: 0.88em;
				line-height: 1.7;
			}
			.post-meta .sep { margin: 0 0.4em; opacity: 0.4; }
			.last-updated { font-style: italic; }
			.post-desc {
				font-size: 1.15em;
				color: var(--text-secondary);
				line-height: 1.6;
				margin-top: 0.5em;
			}

			/* ── Tags ── */
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
				margin-bottom: 1em;
			}

			/* ── Hero Image ── */
			.hero-image { margin-bottom: 2.5em; }
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-md);
			}

			/* ── Prose ── */
			.prose {
				max-width: var(--content-width);
				margin: 0 auto;
				padding: 0;
				color: var(--text-primary);
			}
			.prose h2 { margin-top: 2.5em; }
			.prose h3 { margin-top: 1.5em; }
			.prose p { margin-bottom: 1.5em; line-height: 1.8; }

			/* ── TLDR Callout ── */
			.tldr-block {
				background: var(--bg-secondary);
				border: 1px solid var(--border);
				border-left: 3px solid var(--accent);
				border-radius: var(--radius-md);
				padding: 1.25em 1.5em;
				margin: 1.5em 0;
				font-size: 0.95em;
				color: var(--text-secondary);
			}
			.tldr-block strong:first-child {
				color: var(--accent-light);
				text-transform: uppercase;
				font-size: 0.75em;
				letter-spacing: 0.06em;
			}

			@media (max-width: 720px) {
				.post-header h1 { font-size: 2rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<nav class="breadcrumbs" aria-label="Breadcrumb">
			<a href="/">Home</a><span class="sep">›</span>
			<a href="/blog">Tutorials</a><span class="sep">›</span>
			<span style="color: var(--text-secondary)">{title}</span>
		</nav>
		<main>
			<article itemscope itemtype="https://schema.org/Article">
				<meta itemprop="author" content={author} />
				<meta itemprop="datePublished" content={pubDate.toISOString()} />
				{updatedDate && <meta itemprop="dateModified" content={updatedDate.toISOString()} />}

				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt={`Hero image for ${title}`} itemprop="image" />
					</div>
				)}

				<div class="post-header">
					{tags.length > 0 && (
						<div class="tags">
							{tags.map(tag => <a class="tag" href={`/tags/${tag}`}>{tag}</a>)}
						</div>
					)}
					<h1 itemprop="headline">{title}</h1>
					<div class="post-meta">
						<span>By {author}</span><span class="sep">·</span>
						<FormattedDate date={pubDate} /><span class="sep">·</span>
						<span>{readingTime} min read</span>
						{updatedDate && <><br /><span class="last-updated">Updated <FormattedDate date={updatedDate} /></span></>}
					</div>
					<p class="post-desc" itemprop="description">{description}</p>
				</div>

				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
