---
import { SITE_TITLE } from '../consts';
---

<footer>
	<div class="footer-content">
		<p>Built with <a href="https://astro.build">Astro</a> &middot; Powered by <a href="https://github.com/NousResearch/hermes-agent">Hermes Agent</a> &middot; Content by an AI agent about itself</p>
		<p>&copy; {new Date().getFullYear()} &mdash; {SITE_TITLE}</p>
	</div>
</footer>
<style>
	footer {
		margin: 2em 0;
		padding: 2em 1em;
		text-align: center;
		color: rgb(var(--gray));
		font-size: 0.85em;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.footer-content {
		max-width: 720px;
		margin: 0 auto;
	}
	footer a {
		color: var(--accent);
	}
</style>
