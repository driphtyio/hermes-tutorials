---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo">{SITE_TITLE}</a>
		<button class="hamburger" aria-label="Toggle menu" data-hamburger>
			<span class="hamburger-line"></span>
			<span class="hamburger-line"></span>
			<span class="hamburger-line"></span>
		</button>
		<div class="nav-links" data-nav-links>
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/hosting">Hosting</HeaderLink>
			<HeaderLink href="/providers">Providers</HeaderLink>
			<HeaderLink href="/gateway">Gateway</HeaderLink>
			<HeaderLink href="/tools">Tools</HeaderLink>
			<HeaderLink href="/skills">Skills</HeaderLink>
			<HeaderLink href="/plugins">Plugins</HeaderLink>
			<HeaderLink href="/blog">Tutorials</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/NousResearch/hermes-agent" target="_blank" title="Hermes Agent on GitHub" aria-label="GitHub">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
			</a>
			<a href="https://hermes-agent.nousresearch.com/docs" target="_blank" title="Official Docs" aria-label="Documentation">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(10, 10, 11, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
	}
	nav {
		max-width: var(--grid-width);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 1.5em;
		height: var(--nav-height);
		gap: 2em;
	}
	.logo {
		font-size: 1rem;
		font-weight: 600;
		color: #fff;
		text-decoration: none;
		letter-spacing: -0.01em;
		white-space: nowrap;
	}
	.logo:hover {
		color: var(--accent-light);
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25em;
		flex: 1;
	}
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}
	.social-links a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border-radius: var(--radius-sm);
		color: var(--text-muted);
		transition: all 0.15s ease;
	}
	.social-links a:hover {
		color: #fff;
		background: var(--bg-tertiary);
	}

	/* ── Hamburger ── */
	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: 5px;
		width: 36px;
		height: 36px;
		padding: 0;
		border: none;
		border-radius: var(--radius-sm);
		background: transparent;
		cursor: pointer;
		z-index: 110;
		transition: background 0.15s ease;
	}
	.hamburger:hover {
		background: var(--bg-tertiary);
	}
	.hamburger-line {
		display: block;
		width: 20px;
		height: 2px;
		background: var(--text-secondary);
		border-radius: 2px;
		transition: all 0.2s ease;
	}
	/* Hamburger → X animation */
	header[data-menu-open] .hamburger-line:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}
	header[data-menu-open] .hamburger-line:nth-child(2) {
		opacity: 0;
	}
	header[data-menu-open] .hamburger-line:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	/* ── Mobile nav panel ── */
	@media (max-width: 720px) {
		.social-links { display: none; }
		nav { padding: 0 1em; }

		.hamburger {
			display: flex;
		}

		.nav-links {
			position: fixed;
			top: var(--nav-height);
			left: 0;
			right: 0;
			flex-direction: column;
			align-items: stretch;
			gap: 0;
			padding: 0.5em;
			background: rgba(10, 10, 11, 0.97);
			backdrop-filter: blur(12px);
			-webkit-backdrop-filter: blur(12px);
			border-bottom: 1px solid var(--border);
			opacity: 0;
			transform: translateY(-8px);
			pointer-events: none;
			transition: opacity 0.2s ease, transform 0.2s ease;
		}
		.nav-links a {
			display: block;
			padding: 0.65em 1em;
			border-radius: var(--radius-md);
			text-align: center;
			font-size: 0.95em;
		}
		header[data-menu-open] .nav-links {
			opacity: 1;
			transform: translateY(0);
			pointer-events: auto;
		}
	}
</style>
<script>
	const header = document.querySelector('header');
	const hamburger = document.querySelector('[data-hamburger]');
	const navLinks = document.querySelector('[data-nav-links]');

	if (hamburger && header) {
		hamburger.addEventListener('click', () => {
			const open = header.getAttribute('data-menu-open') === 'true';
			header.setAttribute('data-menu-open', open ? 'false' : 'true');
		});

		// Close menu when a nav link is clicked
		navLinks?.addEventListener('click', (e) => {
			if (e.target.closest('a')) {
				header.setAttribute('data-menu-open', 'false');
			}
		});

		// Close menu on Escape
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && header.getAttribute('data-menu-open') === 'true') {
				header.setAttribute('data-menu-open', 'false');
			}
		});
	}
</script>
